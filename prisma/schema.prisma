// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  auth0Sub           String    @unique
  email              String?
  name               String?
  picture            String?
  xApiKey            String?
  xApiSecret         String?
  xAccessToken       String?
  xAccessTokenSecret String?
  creditBalanceCents    Int       @default(500) // $5.00 initial free credit
  language              String    @default("en")
  // Subscription
  subscriptionTier      String?   // "bronze" | "iron" | "silver" | "gold"
  subscriptionStatus    String?   // "active" | "cancelled" | "past_due"
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  subscriptionPeriodEnd DateTime?
  // Login streak & daily rewards
  loginStreak           Int       @default(0)
  longestStreak         Int       @default(0)
  lastLoginDate         DateTime?
  lastLoginRewardAt     DateTime?
  // Weixin Channel auth
  weixinCookie          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  posts              Post[]
  recurringSchedules RecurringSchedule[]
  knowledgeSources   KnowledgeSource[]
  mediaAssets        MediaAsset[]
  xAccounts          XAccount[]
  usageEvents        UsageEvent[]
  knowledgeImages    KnowledgeImage[]
  creditTransactions CreditTransaction[]
  galleryItems       GalleryItem[]
  webVisits          WebVisit[]
  videoJobs          VideoJob[]
  galleryLikes       GalleryLike[]
  galleryComments    GalleryComment[]
  followers          UserFollow[] @relation("Following")
  following          UserFollow[] @relation("Follower")
  campaigns              Campaign[]
  campaignAttachments    CampaignAttachment[]
}

model CronRunEvent {
  id          String   @id @default(cuid())
  jobName     String
  endpoint    String
  method      String   @default("POST")
  success     Boolean
  statusCode  Int?
  durationMs  Int?
  triggeredBy String?  // cloudflare | vercel | manual | unknown
  error       String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([jobName, createdAt])
  @@index([success, createdAt])
  @@index([endpoint, createdAt])
}

model Post {
  id          String    @id @default(cuid())
  content     String
  mediaUrls   String?   // JSON array of media URLs
  status      String    @default("scheduled") // draft, scheduled, posted, failed
  scheduledAt DateTime?
  postedAt    DateTime?
  tweetId     String?   // ID returned from X API after posting
  impressions Int?      // Fetched from X API public_metrics
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  mediaAssetId String?
  userId       String?
  xAccountId   String?
  user         User?     @relation(fields: [userId], references: [id])
  xAccount     XAccount? @relation(fields: [xAccountId], references: [id])
}

model RecurringSchedule {
  id          String   @id @default(cuid())
  content     String
  useAi       Boolean  @default(false)
  aiPrompt    String?
  aiLanguage  String?
  trendRegion String?  // "global" | "usa" | "china" | "africa" — if set, auto-fetch trending news
  frequency   String   // daily, weekly, monthly
  cronExpr    String   // cron expression
  nextRunAt   DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String?
  xAccountId  String?
  user        User?    @relation(fields: [userId], references: [id])
  xAccount    XAccount? @relation(fields: [xAccountId], references: [id])
}

model KnowledgeSource {
  id           String    @id @default(cuid())
  url          String
  name         String
  type         String    @default("website") // "website" | "weixin_channel"
  content      String    @default("") // Scraped text content
  metadata     String?   // JSON: { videos: VideoMeta[] } for structured data
  pagesScraped Int       @default(1)  // Number of pages scraped
  lastScraped  DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
  images       KnowledgeImage[]
  campaignMaterials CampaignMaterial[]

  @@unique([url, userId])
}

model KnowledgeImage {
  id                String          @id @default(cuid())
  sourceUrl         String
  blobUrl           String
  mimeType          String?
  altText           String?
  mediaType         String          @default("image") // "image" | "video" | "thumbnail"
  duration          Int?            // video duration in seconds
  thumbnailBlobUrl  String?         // for video entries: link to thumbnail blob
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  userId            String?
  user              User?           @relation(fields: [userId], references: [id])
  knowledgeSourceId String
  knowledgeSource   KnowledgeSource @relation(fields: [knowledgeSourceId], references: [id], onDelete: Cascade)

  campaignMaterials CampaignMaterial[]

  @@unique([knowledgeSourceId, sourceUrl])
  @@index([userId, knowledgeSourceId])
  @@index([knowledgeSourceId, mediaType])
}

model MediaAsset {
  id          String   @id @default(cuid())
  sourceUrl   String
  data        Bytes
  mimeType    String   @default("image/jpeg")
  width       Int?
  height      Int?
  altText     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  @@unique([sourceUrl, userId])
}

model XAccount {
  id                 String   @id @default(cuid())
  label              String?
  username           String?
  followersCount     Int?
  followingCount     Int?
  lastSyncedAt       DateTime?
  isDefault          Boolean  @default(false)
  xApiKey            String?
  xApiSecret         String?
  xAccessToken       String
  xAccessTokenSecret String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts              Post[]
  recurringSchedules RecurringSchedule[]

  @@index([userId, isDefault])
}

model UsageEvent {
  id                String   @id @default(cuid())
  provider          String   @default("openai")
  source            String
  model             String?
  promptTokens      Int      @default(0)
  completionTokens  Int      @default(0)
  totalTokens       Int      @default(0)
  metadata          String?
  createdAt         DateTime @default(now())

  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, source, createdAt])
}

model CreditTransaction {
  id              String   @id @default(cuid())
  type            String   // "deduction" | "topup" | "initial"
  amountCents     Int      // positive for top-ups, negative for deductions
  balanceAfter    Int
  description     String?
  stripeSessionId String?
  metadata        String?
  createdAt       DateTime @default(now())

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([stripeSessionId])
}

model GalleryItem {
  id          String   @id @default(cuid())
  type        String   // "image" | "video"
  modelId     String
  modelLabel  String
  prompt      String
  blobUrl     String   // Vercel Blob permanent URL
  sourceUrl   String   // original WaveSpeed URL
  inputImageUrl String?
  generationMeta String?
  aspectRatio String?
  mimeType    String   @default("image/jpeg")
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes       GalleryLike[]
  comments    GalleryComment[]

  @@index([userId, createdAt])
  @@index([isPublic, createdAt])
}

model GalleryLike {
  id        String      @id @default(cuid())
  itemId    String
  userId    String
  createdAt DateTime    @default(now())
  item      GalleryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
  @@index([itemId])
}

model GalleryComment {
  id        String      @id @default(cuid())
  itemId    String
  userId    String
  content   String
  createdAt DateTime    @default(now())
  item      GalleryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model WebVisit {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  sessionId String?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
}

model VideoJob {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Job configuration
  modelId       String
  modelLabel    String
  videoMode     String   // "t2v" | "i2v"
  prompt        String
  segmentCount  Int
  duration      Int      @default(5)
  aspectRatio   String   @default("16:9")
  generateAudio Boolean  @default(false)
  i2vImageUrl   String?
  
  // Job state
  status        String   @default("pending") // "pending" | "processing" | "completed" | "failed"
  
  // Progress tracking (JSON array of segment objects)
  // [{index: 1, status: "completed", outputUrl: "...", error: null}, ...]
  segments      String   @default("[]") // JSON stringified
  
  // Final results
  completedUrls String?  // JSON stringified
  stitchedUrl   String?
  error         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  startedAt     DateTime?
  completedAt   DateTime?
  
  @@index([userId, status])
  @@index([createdAt])
}

model MediaIndustryReport {
  id           String   @id @default(cuid())
  period       String   // "daily" | "weekly"
  reportDate   DateTime // Daily: UTC day start; Weekly: UTC week start (Monday)
  rangeStart   DateTime
  rangeEnd     DateTime
  titleEn      String
  titleZh      String
  summaryEn    String
  summaryZh    String
  highlightsEn String   // JSON stringified string[]
  highlightsZh String   // JSON stringified string[]
  coverImageUrl String?
  sourceCount  Int      @default(0)
  usedAi       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([period, reportDate])
  @@index([period, reportDate])
}

// Raw source articles stored per report run.
// Auto-cleaned after 90 days to keep DB lean.
model MediaNewsSource {
  id          String   @id @default(cuid())
  reportDate  String   // YYYY-MM-DD — matches MediaIndustryReport.reportDate (date string)
  period      String   // "daily" | "weekly"
  title       String
  url         String
  source      String   // outlet name e.g. "The Guardian", "Digiday"
  publishedAt String   // YYYY-MM-DD
  description String
  fullContent   String?  // Full article body — populated for sources that provide it (e.g. The Guardian)
  fullContentZh String?  // Chinese translation of fullContent — populated at cron time
  titleZh       String?  // Chinese translation — populated at cron time
  descriptionZh String?  // Chinese translation — populated at cron time
  imageUrl      String?
  createdAt     DateTime @default(now())

  @@unique([reportDate, period, url])
  @@index([reportDate, period])
  @@index([createdAt])
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  client      String?
  description String?
  status      String    @default("draft") // "draft" | "active" | "completed" | "archived"
  budgetCents Int?
  budgetNote  String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  aiAnalysis  String?
  aiAnalyzedAt DateTime?
  aiBudget    String?
  aiBudgetAt  DateTime?
  shareToken  String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  materials   CampaignMaterial[]
  attachments CampaignAttachment[]
  payment     CampaignPayment?

  @@unique([name, userId])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model CampaignMaterial {
  id                String           @id @default(cuid())
  note              String?
  createdAt         DateTime         @default(now())

  campaignId        String
  campaign          Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  knowledgeSourceId String?
  knowledgeSource   KnowledgeSource? @relation(fields: [knowledgeSourceId], references: [id], onDelete: SetNull)

  knowledgeImageId  String?
  knowledgeImage    KnowledgeImage?  @relation(fields: [knowledgeImageId], references: [id], onDelete: SetNull)

  @@unique([campaignId, knowledgeSourceId])
  @@unique([campaignId, knowledgeImageId])
  @@index([campaignId])
}

model CampaignAttachment {
  id        String   @id @default(cuid())
  fileName  String
  fileType  String
  fileSize  Int
  blobUrl   String
  note      String?
  createdAt DateTime @default(now())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model CampaignPayment {
  id                    String    @id @default(cuid())
  campaignId            String    @unique
  campaign              Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clientName            String
  clientEmail           String
  budgetCents           Int
  platformFeeCents      Int
  totalChargeCents      Int
  ownerPayoutCents      Int
  stripeSessionId       String?   @unique
  stripePaymentIntentId String?
  paymentStatus         String    @default("pending") // "pending" | "paid" | "failed"
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([campaignId])
  @@index([paymentStatus])
}

